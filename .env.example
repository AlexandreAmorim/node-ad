NODE_ENV=development
PORT=3000

# Active Directory Configuration
AD_URL=ldaps://your-dc.domain.com:636
AD_BASE_DN=DC=domain,DC=com
AD_USERNAME=admin@domain.com
AD_PASSWORD=your_admin_password

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here

# TLS Configuration (set to false for self-signed certificates in dev)
AD_TLS_REJECT_UNAUTHORIZED=true